export component LyricsOverlay inherits Window {
    callback request-lock();
    callback request-font-step(step: int);
    callback request-set-palette(index: int);
    callback begin-move();
    callback request-move(dx: length, dy: length);
    callback end-move();
    callback begin-resize();
    callback request-resize(dw: length, dh: length);
    callback end-resize();

    in property <bool> locked: false;
    in property <int> panel_width: 640;
    in property <int> panel_height: 112;
    in property <int> font_scale: 0;
    in property <int> palette_idx: 0;
    private property <bool> palette_open: false;
    in property <string> line_1: "";
    in property <string> line_2: "";
    in property <float> progress_1: 0.0;
    in property <float> progress_2: 0.0;
    in property <float> scroll_1: 0.0;
    in property <float> scroll_2: 0.0;
    in property <float> offset_1: 0.0;
    in property <float> offset_2: 0.0;

    private property <string> lyric_font: "Noto Sans CJK SC, Source Han Sans SC, Noto Sans, sans-serif";
    private property <length> toolbar_h: locked ? 0px : 28px;
    private property <length> content_left: 12px;
    private property <length> content_right: 12px;
    private property <length> content_top: toolbar_h + 6px;
    private property <length> lyric_line_width: panel_width * 1px - content_left - content_right;
    private property <length> primary_font_size: Math.max(18px, (locked ? 32px : 26px) + font_scale * 1px);
    private property <length> secondary_font_size: Math.max(14px, (locked ? 22px : 18px) + font_scale * 1px);

    private property <brush> primary_fill:
        palette_idx == 1
            ? @linear-gradient(180deg, #fff7e8 0%, #ffd27d 55%, #ff9800 100%)
        : palette_idx == 2
            ? @linear-gradient(180deg, #f2f8ff 0%, #95ccff 55%, #2e8fff 100%)
        : palette_idx == 3
            ? @linear-gradient(180deg, #fff1f6 0%, #ff9ebd 55%, #ff4f84 100%)
            : @linear-gradient(180deg, #f7fffb 0%, #56ffc1 56%, #00d17b 100%);
    private property <brush> secondary_fill:
        palette_idx == 1
            ? @linear-gradient(180deg, #fffaf2 0%, #f8d7a4 100%)
        : palette_idx == 2
            ? @linear-gradient(180deg, #f8fbff 0%, #bfd9f8 100%)
        : palette_idx == 3
            ? @linear-gradient(180deg, #fff4f8 0%, #f4bfd2 100%)
            : @linear-gradient(180deg, #ffffff 0%, #d5dde6 100%);
    private property <brush> primary_unplayed_fill: @linear-gradient(180deg, #f8fbff 0%, #bfcad6 100%);
    private property <brush> secondary_unplayed_fill: @linear-gradient(180deg, #eef3f8 0%, #a8b2bf 100%);

    background: transparent;

    Rectangle {
        width: panel_width * 1px;
        height: panel_height * 1px;
        background: locked ? #00000000 : #000000aa;
        border-width: locked ? 0px : 1px;
        border-color: #ffffff1f;
        border-radius: 0px;

        if !locked : Rectangle {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            height: toolbar_h - 4px;
            background: #ffffff14;
            border-width: 1px;
            border-color: #ffffff1f;

            Rectangle {
                x: 8px;
                y: 3px;
                width: 44px;
                height: parent.height - 6px;
                background: lock_touch.pressed ? #00000068 : lock_touch.has-hover ? #ffffff2a : #00000038;
                animate background { duration: 120ms; easing: ease-out; }

                Text {
                    text: "锁定";
                    color: #f8fbff;
                    font-family: lyric_font;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                lock_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-lock();
                    }
                }
            }

            Rectangle {
                x: parent.width - 110px;
                y: 3px;
                width: 28px;
                height: parent.height - 6px;
                background: font_minus_touch.pressed ? #00000068 : font_minus_touch.has-hover ? #ffffff2a : #00000038;
                animate background { duration: 120ms; easing: ease-out; }

                Text {
                    text: "A-";
                    color: #f8fbff;
                    font-family: lyric_font;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                font_minus_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-font-step(-1);
                    }
                }
            }

            Rectangle {
                x: parent.width - 78px;
                y: 3px;
                width: 28px;
                height: parent.height - 6px;
                background: font_plus_touch.pressed ? #00000068 : font_plus_touch.has-hover ? #ffffff2a : #00000038;
                animate background { duration: 120ms; easing: ease-out; }

                Text {
                    text: "A+";
                    color: #f8fbff;
                    font-family: lyric_font;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                font_plus_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-font-step(1);
                    }
                }
            }

            Rectangle {
                x: parent.width - 46px;
                y: 3px;
                width: 38px;
                height: parent.height - 6px;
                background: palette_touch.pressed ? #00000068 : palette_touch.has-hover ? #ffffff2a : #00000038;
                animate background { duration: 120ms; easing: ease-out; }

                Text {
                    text: "配色";
                    color: #f8fbff;
                    font-family: lyric_font;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                palette_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.palette_open = !root.palette_open;
                    }
                }
            }
        }

        if !locked && palette_open : Rectangle {
            x: parent.width - 166px;
            y: toolbar_h + 4px;
            width: 154px;
            height: 40px;
            background: #000000c0;
            border-width: 1px;
            border-color: #ffffff1f;

            Rectangle {
                x: 8px;
                y: 8px;
                width: 28px;
                height: 24px;
                background: #56ffc1;
                border-width: palette_0_touch.pressed || palette_0_touch.has-hover || palette_idx == 0 ? 2px : 1px;
                border-color: #f8fbff;
                animate background { duration: 120ms; easing: ease-out; }

                palette_0_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-set-palette(0);
                        root.palette_open = false;
                    }
                }
            }

            Rectangle {
                x: 42px;
                y: 8px;
                width: 28px;
                height: 24px;
                background: #ff9800;
                border-width: palette_1_touch.pressed || palette_1_touch.has-hover || palette_idx == 1 ? 2px : 1px;
                border-color: #f8fbff;
                animate background { duration: 120ms; easing: ease-out; }

                palette_1_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-set-palette(1);
                        root.palette_open = false;
                    }
                }
            }

            Rectangle {
                x: 76px;
                y: 8px;
                width: 28px;
                height: 24px;
                background: #2e8fff;
                border-width: palette_2_touch.pressed || palette_2_touch.has-hover || palette_idx == 2 ? 2px : 1px;
                border-color: #f8fbff;
                animate background { duration: 120ms; easing: ease-out; }

                palette_2_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-set-palette(2);
                        root.palette_open = false;
                    }
                }
            }

            Rectangle {
                x: 110px;
                y: 8px;
                width: 28px;
                height: 24px;
                background: #ff4f84;
                border-width: palette_3_touch.pressed || palette_3_touch.has-hover || palette_idx == 3 ? 2px : 1px;
                border-color: #f8fbff;
                animate background { duration: 120ms; easing: ease-out; }

                palette_3_touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.request-set-palette(3);
                        root.palette_open = false;
                    }
                }
            }
        }

        Text {
            x: content_left + 1px + offset_1 * 1px - scroll_1 * 1px;
            y: content_top + 2px;
            width: lyric_line_width;
            text: line_1;
            color: #000000c4;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left + offset_1 * 1px - scroll_1 * 1px;
            y: content_top;
            width: lyric_line_width;
            text: line_1;
            color: primary_unplayed_fill;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #04110de0;
            stroke-width: 1.6px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: content_top;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_1, 1.0));
            height: primary_font_size + 6px;
            clip: true;
            background: #00000000;

            Text {
                x: offset_1 * 1px - scroll_1 * 1px;
                y: 0px;
                width: lyric_line_width;
                text: line_1;
                color: primary_fill;
                font-family: lyric_font;
                font-size: primary_font_size;
                font-weight: 800;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #04110de0;
                stroke-width: 1.6px;
                stroke-style: outside;
            }
        }

        Text {
            x: content_left + 1px + offset_2 * 1px - scroll_2 * 1px;
            y: content_top + primary_font_size + 10px;
            width: lyric_line_width;
            text: line_2;
            color: #0000009a;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left + offset_2 * 1px - scroll_2 * 1px;
            y: content_top + primary_font_size + 8px;
            width: lyric_line_width;
            text: line_2;
            color: secondary_unplayed_fill;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #0a1119c8;
            stroke-width: 1.1px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: content_top + primary_font_size + 8px;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_2, 1.0));
            height: secondary_font_size + 6px;
            clip: true;
            background: #00000000;

            Text {
                x: offset_2 * 1px - scroll_2 * 1px;
                y: 0px;
                width: lyric_line_width;
                text: line_2;
                color: secondary_fill;
                font-family: lyric_font;
                font-size: secondary_font_size;
                font-weight: 650;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #0a1119c8;
                stroke-width: 1.1px;
                stroke-style: outside;
            }
        }

        if !locked : Rectangle {
            x: parent.width - 16px;
            y: parent.height - 16px;
            width: 10px;
            height: 10px;
            background: #ffffffa8;
        }

        if !locked : TouchArea {
            y: toolbar_h;
            width: parent.width;
            height: parent.height - toolbar_h;
            mouse-cursor: move;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-move();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-move();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked : TouchArea {
            x: parent.width - 24px;
            y: parent.height - 24px;
            width: 24px;
            height: 24px;
            mouse-cursor: se-resize;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-resize();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-resize();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-resize(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }
    }
}