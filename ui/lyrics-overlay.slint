export component LyricsOverlay inherits Window {
    callback request-lock();
    callback begin-move();
    callback request-move(dx: length, dy: length);
    callback begin-resize();
    callback request-resize(dw: length, dh: length);

    in property <bool> locked: false;
    in property <int> panel_width: 640;
    in property <int> panel_height: 88;
    in property <string> line_1: "";
    in property <string> line_2: "";

    background: transparent;

    Rectangle {
        width: panel_width * 1px;
        height: panel_height * 1px;
        background: locked ? #00000000 : #0f1117aa;
        border-width: locked ? 0px : 1px;
        border-color: #ffffff20;
        border-radius: locked ? 0px : 20px;

        Text {
            x: locked ? 0px : 18px;
            y: locked ? 0px : 14px;
            width: parent.width - (locked ? 0px : 90px);
            text: line_1;
            color: #ffffff;
            font-size: locked ? 26px : 22px;
            font-weight: 700;
            wrap: word-wrap;
            vertical-alignment: center;
        }

        Text {
            x: locked ? 0px : 18px;
            y: locked ? 34px : 48px;
            width: parent.width - (locked ? 0px : 90px);
            text: line_2;
            color: #d3dae5;
            font-size: locked ? 18px : 16px;
            wrap: word-wrap;
            vertical-alignment: center;
        }

        if !locked : Rectangle {
            x: parent.width - 74px;
            y: 12px;
            width: 56px;
            height: 30px;
            background: #ffffff16;
            border-radius: 10px;

            Text {
                text: "锁定";
                color: #f8fafc;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            TouchArea {
                clicked => {
                    root.request-lock();
                }
            }
        }

        if !locked : Rectangle {
            x: parent.width - 16px;
            y: parent.height - 16px;
            width: 10px;
            height: 10px;
            background: #7dc2ffcc;
            border-radius: 3px;
        }

        if !locked : TouchArea {
            mouse-cursor: move;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-move();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked : TouchArea {
            x: parent.width - 24px;
            y: parent.height - 24px;
            width: 24px;
            height: 24px;
            mouse-cursor: se-resize;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-resize();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-resize(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }
    }
}
