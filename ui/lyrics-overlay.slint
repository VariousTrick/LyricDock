component ToolbarIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label: "";
    in property <bool> selected: false;
    in property <bool> enabled: true;

    callback clicked();

    width: 26px;
    height: 26px;
    border-radius: 7px;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => {
        touch_area.clicked();
    }

    background: !root.enabled
        ? #ffffff08
        : touch_area.pressed
            ? #ffffff2f
            : touch_area.has-hover
                ? #ffffff1d
                : root.selected
                    ? #ffffff16
                    : #00000000;
    border-width: root.selected ? 1px : 0px;
    border-color: #ffffff30;
    animate background, border-color { duration: 120ms; easing: ease-out; }

    icon_image := Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 13px;
        height: 13px;
        source: root.icon;
        image-fit: contain;
        colorize: #f8fbff;
        accessible-role: none;
    }

    touch_area := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component LyricsOverlay inherits Window {
    callback request-lock();
    callback request-font-step(step: int);
    callback request-set-palette(color: string);
    callback begin-move();
    callback request-move(dx: length, dy: length);
    callback end-move();
    callback begin-resize();
    callback request-resize(dw: length, dh: length);
    callback end-resize();

    in property <bool> locked: false;
    in property <int> panel_width: 640;
    in property <int> panel_height: 112;
    in property <int> font_scale: 0;
    in property <string> palette_color: "#56ffc1";
    private property <bool> palette_open: false;
    in property <string> line_1: "";
    in property <string> line_2: "";
    in property <float> progress_1: 0.0;
    in property <float> progress_2: 0.0;
    in property <float> scroll_1: 0.0;
    in property <float> scroll_2: 0.0;
    in property <float> offset_1: 0.0;
    in property <float> offset_2: 0.0;

    private property <string> lyric_font: "Noto Sans CJK SC, Source Han Sans SC, Noto Sans, sans-serif";
    private property <length> toolbar_h: locked ? 0px : 30px;
    private property <length> content_left: 12px;
    private property <length> content_right: 12px;
    private property <length> content_top: toolbar_h + 6px;
    private property <length> lyric_line_width: panel_width * 1px - content_left - content_right;
    private property <length> primary_font_size: Math.max(18px, (locked ? 32px : 26px) + font_scale * 1px);
    private property <length> secondary_font_size: Math.max(14px, (locked ? 22px : 18px) + font_scale * 1px);

    private property <brush> primary_fill: @linear-gradient(180deg, #56ffc1 0%, #56ffc1 55%, #56ffc1 100%);
    private property <brush> secondary_fill: @linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.6) 100%);
    private property <brush> primary_unplayed_fill: @linear-gradient(180deg, #f8fbff 0%, #bfcad6 100%);
    private property <brush> secondary_unplayed_fill: @linear-gradient(180deg, #eef3f8 0%, #a8b2bf 100%);

    background: transparent;

    Rectangle {
        width: panel_width * 1px;
        height: panel_height * 1px;
        background: locked ? #00000000 : #000000aa;
        border-width: locked ? 0px : 1px;
        border-color: #ffffff1f;
        border-radius: 0px;

        if !locked : Rectangle {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            height: toolbar_h - 4px;
            background: #ffffff12;
            border-width: 1px;
            border-color: #ffffff18;

            HorizontalLayout {
                x: 8px;
                y: 2px;
                width: parent.width - 16px;
                height: parent.height - 4px;
                spacing: 4px;
                alignment: end;

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-lock.svg");
                    label: "锁定歌词";
                    clicked => {
                        root.request-lock();
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-minus.svg");
                    label: "缩小歌词";
                    clicked => {
                        root.request-font-step(-1);
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-plus.svg");
                    label: "放大歌词";
                    clicked => {
                        root.request-font-step(1);
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-palette.svg");
                    label: "切换配色";
                    selected: palette_open;
                    clicked => {
                        root.palette_open = !root.palette_open;
                    }
                }
            }
        }

        if !locked && palette_open : Rectangle {
            x: parent.width - 240px;
            y: toolbar_h + 5px;
            width: 228px;
            height: 48px;
            background: #000000c8;
            border-width: 1px;
            border-color: #ffffff1f;
            border-radius: 12px;

            VerticalLayout {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                spacing: 4px;

                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;

                    Text {
                        text: "颜色: #";
                        color: #ffffff;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    palette_input := TextInput {
                        width: 120px;
                        height: 20px;
                        text: root.palette_color;
                        color: #000000;
                        selection-background-color: #56ffc1;
                        font-size: 12px;
                        input-type: text;
                        accepted => {
                            root.request-set-palette(self.text);
                            root.palette_open = false;
                        }
                    }
                }

                Text {
                    text: "按 Enter 确认";
                    color: #ffffff99;
                    font-size: 10px;
                }
            }
        }

        Text {
            x: content_left + 1px + offset_1 * 1px - scroll_1 * 1px;
            y: content_top + 2px;
            width: lyric_line_width;
            text: line_1;
            color: #000000c4;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left + offset_1 * 1px - scroll_1 * 1px;
            y: content_top;
            width: lyric_line_width;
            text: line_1;
            color: primary_unplayed_fill;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #04110de0;
            stroke-width: 1.6px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: content_top;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_1, 1.0));
            height: primary_font_size + 6px;
            clip: true;
            background: #00000000;

            Text {
                x: offset_1 * 1px - scroll_1 * 1px;
                y: 0px;
                width: lyric_line_width;
                text: line_1;
                color: primary_fill;
                font-family: lyric_font;
                font-size: primary_font_size;
                font-weight: 800;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #04110de0;
                stroke-width: 1.6px;
                stroke-style: outside;
            }
        }

        Text {
            x: content_left + 1px + offset_2 * 1px - scroll_2 * 1px;
            y: content_top + primary_font_size + 10px;
            width: lyric_line_width;
            text: line_2;
            color: #0000009a;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left + offset_2 * 1px - scroll_2 * 1px;
            y: content_top + primary_font_size + 8px;
            width: lyric_line_width;
            text: line_2;
            color: secondary_unplayed_fill;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #0a1119c8;
            stroke-width: 1.1px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: content_top + primary_font_size + 8px;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_2, 1.0));
            height: secondary_font_size + 6px;
            clip: true;
            background: #00000000;

            Text {
                x: offset_2 * 1px - scroll_2 * 1px;
                y: 0px;
                width: lyric_line_width;
                text: line_2;
                color: secondary_fill;
                font-family: lyric_font;
                font-size: secondary_font_size;
                font-weight: 650;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #0a1119c8;
                stroke-width: 1.1px;
                stroke-style: outside;
            }
        }

        if !locked : Rectangle {
            x: parent.width - 16px;
            y: parent.height - 16px;
            width: 10px;
            height: 10px;
            background: #ffffffa8;
        }

        if !locked : TouchArea {
            y: toolbar_h;
            width: parent.width;
            height: parent.height - toolbar_h;
            mouse-cursor: move;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-move();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-move();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked : TouchArea {
            x: parent.width - 24px;
            y: parent.height - 24px;
            width: 24px;
            height: 24px;
            mouse-cursor: se-resize;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-resize();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-resize();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-resize(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }
    }
}