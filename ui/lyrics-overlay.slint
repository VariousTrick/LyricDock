component ToolbarIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label: "";
    in property <bool> selected: false;
    in property <bool> enabled: true;

    callback clicked();

    width: 40px;
    height: 40px;
    border-radius: 10px;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => {
        touch_area.clicked();
    }

    background: !root.enabled
        ? #ffffff0d
        : touch_area.pressed
            ? #ffffff3a
            : touch_area.has-hover
                ? #ffffff22
                : root.selected
                    ? #ffffff1a
                    : #00000000;
    border-width: root.selected ? 1px : 0px;
    border-color: #ffffff40;
    animate background, border-color { duration: 120ms; easing: ease-out; }

    icon_image := Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: #f8fbff;
        accessible-role: none;
    }

    touch_area := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component LyricsOverlay inherits Window {
    callback request-lock();
    callback request-font-step(step: int);
    callback request-set-palette(color: string);
    callback begin-move();
    callback request-move(dx: length, dy: length);
    callback end-move();
    callback begin-resize();
    callback request-resize(dw: length, dh: length);
    callback end-resize();

    in property <bool> locked: false;
    in property <int> panel_width: 640;
    in property <int> panel_height: 112;
    in property <int> font_scale: 0;
    in property <string> palette_color: "#56ffc1";
    private property <bool> palette_open: false;
    in property <string> line_1: "";
    in property <string> line_2: "";
    in property <float> progress_1: 0.0;
    in property <float> progress_2: 0.0;
    in property <float> scroll_1: 0.0;
    in property <float> scroll_2: 0.0;
    in property <float> offset_1: 0.0;
    in property <float> offset_2: 0.0;

    private property <string> lyric_font: "Noto Sans CJK SC, Source Han Sans SC, Noto Sans, sans-serif";
    private property <length> toolbar_h: 0px;
    private property <length> button_area_h: locked ? 0px : 50px;
    private property <length> content_left: 12px;
    private property <length> content_right: 12px;
    private property <length> content_top: 6px;
    private property <length> content_bottom: 6px + button_area_h;
    private property <length> available_height: panel_height * 1px - content_top - content_bottom;
    private property <length> lyric_line_width: panel_width * 1px - content_left - content_right;
    private property <length> primary_font_size: Math.max(18px, (locked ? 32px : 26px) + font_scale * 1px);
    private property <length> secondary_font_size: Math.max(14px, (locked ? 22px : 18px) + font_scale * 1px);

    private property <brush> primary_fill: @linear-gradient(180deg, #56ffc1 0%, #56ffc1 55%, #56ffc1 100%);
    private property <brush> secondary_fill: @linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.6) 100%);
    private property <brush> primary_unplayed_fill: @linear-gradient(180deg, #f8fbff 0%, #bfcad6 100%);
    private property <brush> secondary_unplayed_fill: @linear-gradient(180deg, #eef3f8 0%, #a8b2bf 100%);
    private property <brush> panel_background: @linear-gradient(180deg, #00000080 0%, #00000095 50%, #000000aa 100%);

    background: transparent;

    Rectangle {
        width: panel_width * 1px;
        height: panel_height * 1px;
        background: locked ? #00000000 : panel_background;
        border-width: locked ? 0px : 1px;
        border-color: #ffffff28;
        border-radius: 8px;

        if !locked : Rectangle {
            x: (parent.width - 180px) / 2;
            y: parent.height - button_area_h;
            width: 180px;
            height: button_area_h;
            background: #00000000;

            HorizontalLayout {
                x: 0px;
                y: 5px;
                width: parent.width;
                height: 40px;
                spacing: 8px;
                alignment: center;

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-lock.svg");
                    label: "锁定歌词";
                    clicked => {
                        root.request-lock();
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-minus.svg");
                    label: "缩小歌词";
                    clicked => {
                        root.request-font-step(-1);
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-plus.svg");
                    label: "放大歌词";
                    clicked => {
                        root.request-font-step(1);
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-palette.svg");
                    label: "切换配色";
                    selected: palette_open;
                    clicked => {
                        root.palette_open = !root.palette_open;
                    }
                }
            }
        }

        Text {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2 + 2px;
            width: lyric_line_width;
            text: line_1;
            color: #000000c4;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2;
            width: lyric_line_width;
            text: line_1;
            color: primary_unplayed_fill;
            font-family: lyric_font;
            font-size: primary_font_size;
            font-weight: 800;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #04110de0;
            stroke-width: 1.6px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_1, 1.0));
            height: primary_font_size + 6px;
            clip: true;
            background: #00000000;
            border-radius: 3px;

            Text {
                x: 0px;
                y: 0px;
                width: lyric_line_width;
                text: line_1;
                color: primary_fill;
                font-family: lyric_font;
                font-size: primary_font_size;
                font-weight: 800;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #04110de0;
                stroke-width: 1.6px;
                stroke-style: outside;
            }
        }

        Text {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2 + primary_font_size + 10px + 1px;
            width: lyric_line_width;
            text: line_2;
            color: #0000009a;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2 + primary_font_size + 8px;
            width: lyric_line_width;
            text: line_2;
            color: secondary_unplayed_fill;
            font-family: lyric_font;
            font-size: secondary_font_size;
            font-weight: 650;
            wrap: no-wrap;
            overflow: clip;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #0a1119c8;
            stroke-width: 1.1px;
            stroke-style: outside;
        }

        Rectangle {
            x: content_left;
            y: (panel_height * 1px - button_area_h - primary_font_size - secondary_font_size - 10px) / 2 + primary_font_size + 8px;
            width: lyric_line_width * Math.max(0.0, Math.min(progress_2, 1.0));
            height: secondary_font_size + 6px;
            clip: true;
            background: #00000000;
            border-radius: 2px;

            Text {
                x: 0px;
                y: 0px;
                width: lyric_line_width;
                text: line_2;
                color: secondary_fill;
                font-family: lyric_font;
                font-size: secondary_font_size;
                font-weight: 650;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: center;
                vertical-alignment: center;
                stroke: #0a1119c8;
                stroke-width: 1.1px;
                stroke-style: outside;
            }
        }

        if !locked : Rectangle {
            x: parent.width - 16px;
            y: parent.height - 16px;
            width: 10px;
            height: 10px;
            background: #ffffffa8;
            border-radius: 2px;
        }

        if !locked : TouchArea {
            width: parent.width;
            height: parent.height - button_area_h;
            mouse-cursor: move;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-move();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-move();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked : TouchArea {
            x: parent.width - 24px;
            y: parent.height - 24px;
            width: 24px;
            height: 24px;
            mouse-cursor: se-resize;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-resize();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-resize();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-resize(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked && palette_open : Rectangle {
            x: (parent.width - 228px) / 2;
            y: 10px;
            width: 228px;
            height: 54px;
            background: @linear-gradient(180deg, #000000d8 0%, #000000e0 100%);
            border-width: 1px;
            border-color: #ffffff2f;
            border-radius: 8px;

            VerticalLayout {
                x: 8px;
                y: 7px;
                width: parent.width - 16px;
                height: parent.height - 14px;
                spacing: 3px;

                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;

                    Text {
                        text: "颜色: #";
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    input_box := Rectangle {
                        width: 120px;
                        height: 22px;
                        background: #111111e6;
                        border-width: 1px;
                        border-color: #ffffff26;
                        border-radius: 4px;

                        palette_input := TextInput {
                            x: 6px;
                            y: 2px;
                            width: parent.width - 12px;
                            height: parent.height - 4px;
                            text: root.palette_color;
                            color: #f8fbff;
                            selection-background-color: #56ffc1;
                            font-size: 12px;
                            input-type: text;
                            accepted => {
                                root.request-set-palette(self.text);
                                root.palette_open = false;
                            }
                        }
                    }
                }

                Text {
                    text: "按 Enter 确认";
                    color: #ffffff99;
                    font-size: 10px;
                }
            }
        }
    }
}