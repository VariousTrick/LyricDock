component ToolbarIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label: "";
    in property <bool> selected: false;
    in property <bool> enabled: true;

    callback clicked();

    width: 40px;
    height: 40px;
    border-radius: 10px;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => {
        touch_area.clicked();
    }

    background: !root.enabled
        ? #ffffff0d
        : touch_area.pressed
            ? #ffffff3a
            : touch_area.has-hover
                ? #ffffff22
                : root.selected
                    ? #ffffff1a
                    : #00000000;
    border-width: root.selected ? 1px : 0px;
    border-color: #ffffff40;
    animate background, border-color { duration: 120ms; easing: ease-out; }

    icon_image := Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        source: root.icon;
        image-fit: contain;
        colorize: #f8fbff;
        accessible-role: none;
    }

    touch_area := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export struct KaraokeSegment {
    text: string,
    progress: float,
}

component KaraokeLine inherits Rectangle {
    in property <[KaraokeSegment]> segments;
    in property <length> font_size;
    in property <string> font_family;
    in property <brush> played_fill;
    in property <brush> unplayed_fill;
    in property <brush> stroke_color;
    in property <float> stroke_width;
    in property <int> font_weight: 800;
    in property <float> opacity_value: 1.0;

    background: #00000000;
    width: max(1px, row.preferred-width);
    height: font_size + 10px;
    opacity: opacity_value;

    row := HorizontalLayout {
        x: 0px;
        y: 0px;
        spacing: 0px;

        for segment[index] in root.segments : Rectangle {
            background: #00000000;
            private property <length> segment_width: max(base_text.preferred-width, 1px);
            private property <length> segment_height: root.height;
            min-width: segment_width;
            preferred-width: segment_width;
            height: segment_height;

            base_text := Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                text: segment.text;
                color: root.unplayed_fill;
                font-family: root.font_family;
                font-size: root.font_size;
                font-weight: root.font_weight;
                wrap: no-wrap;
                overflow: clip;
                horizontal-alignment: left;
                vertical-alignment: center;
                stroke: root.stroke_color;
                stroke-width: root.stroke_width * 1px;
                stroke-style: outside;
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width * Math.max(0.0, Math.min(segment.progress, 1.0));
                height: parent.height;
                clip: true;
                background: #00000000;

                Text {
                    x: 0px;
                    y: 0px;
                    width: segment_width;
                    height: segment_height;
                    text: segment.text;
                    color: root.played_fill;
                    font-family: root.font_family;
                    font-size: root.font_size;
                    font-weight: root.font_weight;
                    wrap: no-wrap;
                    overflow: clip;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    stroke: root.stroke_color;
                    stroke-width: root.stroke_width * 1px;
                    stroke-style: outside;
                }
            }
        }
    }
}

export component LyricsOverlay inherits Window {
    callback request-lock();
    callback request-font-step(step: int);
    callback begin-move();
    callback request-move(dx: length, dy: length);
    callback end-move();
    callback begin-resize();
    callback request-resize(dw: length, dh: length);
    callback end-resize();

    in property <bool> locked: false;
    in property <int> panel_width: 640;
    in property <int> panel_height: 112;
    in property <int> font_scale: 0;
    in property <bool> show_secondary_line: true;
    in property <bool> use_gradient: false;
    in property <string> lyric_effect: "flat";
    in property <string> lyric_font: "PingFang SC, SF Pro Display, HarmonyOS Sans SC, Noto Sans CJK SC, sans-serif";
    in property <brush> highlight_color: #00e676;
    in property <brush> base_color: #f5f7fb;
    in property <brush> preview_color: #f5f7fb;
    in property <brush> stroke_color: #081019e0;
    in property <float> stroke_width: 3.2;
    in property <brush> shadow_color: #000000c4;
    in property <brush> panel_background_brush: #00000095;
    in property <brush> panel_border_brush: #ffffff28;
    in property <brush> resize_handle_brush: #ffffffa8;
    in property <float> lyrics_opacity: 1.0;
    in property <float> preview_opacity: 1.0;
    in property <string> line_1: "";
    in property <string> line_2: "";
    in property <[KaraokeSegment]> line_1_segments: [];
    in property <[KaraokeSegment]> line_2_segments: [];
    in property <float> progress_1: 0.0;
    in property <float> progress_2: 0.0;
    in property <bool> line_1_active: true;
    in property <bool> line_2_active: false;
    in property <float> scroll_1: 0.0;
    in property <float> scroll_2: 0.0;
    in property <float> offset_1: 0.0;
    in property <float> offset_2: 0.0;

    private property <length> toolbar_h: 0px;
    private property <length> button_area_h: locked ? 0px : 50px;
    private property <length> content_left: 12px;
    private property <length> content_right: 12px;
    private property <length> content_top: 6px;
    private property <length> content_bottom: 6px + button_area_h;
    private property <length> available_height: panel_height * 1px - content_top - content_bottom;
    private property <length> lyric_line_width: panel_width * 1px - content_left - content_right;
    private property <length> primary_font_size: Math.max(18px, (locked ? 33px : 27px) + font_scale * 1px);
    private property <length> secondary_font_size: primary_font_size;
    private property <bool> show_second: show_secondary_line && line_2 != "";
    private property <length> line_gap: show_second ? 10px : 0px;
    private property <length> active_primary_font_size: primary_font_size;
    private property <length> lyric_block_height: active_primary_font_size + (show_second ? secondary_font_size + line_gap : 0px);
    private property <length> lyric_top: (panel_height * 1px - button_area_h - lyric_block_height) / 2;
    private property <length> primary_wave_offset: 0px;
    private property <bool> use_flat_effect: lyric_effect == "flat";

    private property <brush> primary_fill_gradient: @linear-gradient(180deg, #ffffff 0%, #fbfcff 55%, #edf2f8 100%);
    private property <brush> primary_unplayed_fill_gradient: @linear-gradient(180deg, #dde3ec 0%, #c2cbd6 100%);
    private property <brush> primary_fill: use_gradient ? primary_fill_gradient : primary_fill_solid;
    private property <brush> primary_unplayed_fill: use_gradient ? primary_unplayed_fill_gradient : primary_unplayed_fill_solid;
    private property <brush> primary_fill_solid: highlight_color;
    private property <brush> primary_unplayed_fill_solid: base_color;
    private property <brush> line_1_fill: line_1_active ? primary_fill : preview_color;
    private property <brush> line_2_fill: line_2_active ? primary_fill : preview_color;
    private property <brush> line_1_unplayed_fill: line_1_active ? primary_unplayed_fill : preview_color;
    private property <brush> line_2_unplayed_fill: line_2_active ? primary_unplayed_fill : preview_color;
    private property <float> line_1_opacity: lyrics_opacity;
    private property <float> line_2_opacity: lyrics_opacity;
    private property <float> line_1_shadow_opacity: (line_1_active ? 0.48 : 0.24) * lyrics_opacity;
    private property <float> line_2_shadow_opacity: (line_2_active ? 0.38 : 0.18) * lyrics_opacity;
    private property <length> line_1_lift: use_flat_effect ? 0px : (line_1_active ? -1px : 0px);
    private property <length> line_2_lift: use_flat_effect ? 0px : (line_2_active ? -0.5px : 0px);
    private property <float> line_1_glow_opacity: use_flat_effect ? 0.0 : (line_1_active ? 0.10 : 0.0) * lyrics_opacity;
    private property <float> line_2_glow_opacity: use_flat_effect ? 0.0 : (line_2_active ? 0.06 : 0.0) * lyrics_opacity;
    private property <float> line_1_stroke_active: use_flat_effect ? stroke_width * 1.18 : stroke_width * 1.0;
    private property <float> line_1_stroke_inactive: use_flat_effect ? stroke_width * 0.92 : stroke_width * 0.75;
    private property <float> line_2_stroke_active: use_flat_effect ? stroke_width * 0.98 : stroke_width * 0.82;
    private property <float> line_2_stroke_inactive: use_flat_effect ? stroke_width * 0.74 : stroke_width * 0.6;
    background: transparent;

    Rectangle {
        width: panel_width * 1px;
        height: panel_height * 1px;
        background: locked ? #00000000 : panel_background_brush;
        border-width: locked ? 0px : 1px;
        border-color: panel_border_brush;
        border-radius: 8px;

        if !locked : Rectangle {
            x: (parent.width - 132px) / 2;
            y: parent.height - button_area_h;
            width: 132px;
            height: button_area_h;
            background: #00000000;

            HorizontalLayout {
                x: 0px;
                y: 5px;
                width: parent.width;
                height: 40px;
                spacing: 8px;
                alignment: center;

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-lock.svg");
                    label: "锁定歌词";
                    clicked => {
                        root.request-lock();
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-minus.svg");
                    label: "缩小歌词";
                    clicked => {
                        root.request-font-step(-1);
                    }
                }

                ToolbarIconButton {
                    icon: @image-url("../assets/toolbar-plus.svg");
                    label: "放大歌词";
                    clicked => {
                        root.request-font-step(1);
                    }
                }

            }
        }

        KaraokeLine {
            x: (parent.width - self.width) / 2;
            y: lyric_top + primary_wave_offset + line_1_lift;
            segments: line_1_segments;
            font_size: active_primary_font_size;
            font_family: lyric_font;
            played_fill: line_1_fill;
            unplayed_fill: line_1_unplayed_fill;
            stroke_color: stroke_color;
            stroke_width: line_1_active ? line_1_stroke_active : line_1_stroke_inactive;
            font_weight: line_1_active ? 830 : 720;
            opacity_value: line_1_opacity;
            animate y, opacity_value { duration: 260ms; easing: ease-out; }
        }

        KaraokeLine {
            x: (parent.width - self.width) / 2;
            y: lyric_top + active_primary_font_size + line_gap + line_2_lift;
            segments: line_2_segments;
            font_size: secondary_font_size;
            font_family: lyric_font;
            played_fill: line_2_fill;
            unplayed_fill: line_2_unplayed_fill;
            stroke_color: stroke_color;
            stroke_width: line_2_active ? line_2_stroke_active : line_2_stroke_inactive;
            font_weight: line_2_active ? 810 : 670;
            opacity_value: show_second ? line_2_opacity : 0;
            animate y, opacity_value { duration: 260ms; easing: ease-out; }
        }

        if !locked : Rectangle {
            x: parent.width - 16px;
            y: parent.height - 16px;
            width: 10px;
            height: 10px;
            background: resize_handle_brush;
            border-radius: 2px;
        }

        if !locked : TouchArea {
            width: parent.width;
            height: parent.height - button_area_h;
            mouse-cursor: move;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-move();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-move();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-move(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }

        if !locked : TouchArea {
            x: parent.width - 24px;
            y: parent.height - 24px;
            width: 24px;
            height: 24px;
            mouse-cursor: se-resize;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.begin-resize();
                }
                if (event.kind == PointerEventKind.up) {
                    root.end-resize();
                }
            }
            moved => {
                if (self.pressed) {
                    root.request-resize(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                }
            }
        }
    }
}
